# Cross-editor whitespace and encoding consistency.
# See https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4
max_line_length = 150

[{*.html,*.css,*.js,*.json,*.yml,*.yaml,*.toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
# Markdown line-trailing spaces matter (force-break)
trim_trailing_whitespace = false
